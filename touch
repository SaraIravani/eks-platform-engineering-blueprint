apiVersion: v1
kind: Pod
metadata:
  name: persistence-test
  namespace: api
spec:
  nodeSelector:
    workload: api
  containers:
    - name: app
      image: busybox
      command: ["sh", "-c", "echo 'hello from gp3' > /data/test.txt && sleep 3600"]
      volumeMounts:
        - name: data
          mountPath: /data
  volumes:
    - name: data
      persistentVolumeClaim:
        claimName: gp3-test-pvc
